PUBLIC_SANITY_PROJECT_ID=your-project-id
PUBLIC_SANITY_DATASET=production
# Toggle to quickly roll back to Markdown/static content without removing env vars
PUBLIC_USE_SANITY=true
# Optional: add SANITY_READ_TOKEN for preview endpoints later
# SANITY_READ_TOKEN=

# Optional canonical site URL for Astro config (used in meta tags/open graph)
# SITE_URL=https://your-production-domain
