---
import Layout from '../../components/Layout.astro';
import '../../styles/lookbook.css';
import { getStrings } from '../../i18n/getStrings';
import { LOCALE_CODES, type Locale } from '../../i18n/config';
import LookbookContent from '../../components/pages/LookbookContent.astro';

export function getStaticPaths() {
	return LOCALE_CODES.filter((l) => l !== 'en').map((locale) => ({
		params: { locale },
	}));
}

const locale = Astro.params.locale as Locale;
const ui = await getStrings(locale);
---
<Layout title={`${ui.seo.siteTitle} - ${ui.nav.lookbook}`} locale={locale} ui={ui}>
  <LookbookContent />
</Layout>
