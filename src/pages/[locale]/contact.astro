---
import Layout from '../../components/Layout.astro';
import '../../styles/contact.css';
import { getStrings } from '../../i18n/getStrings';
import { LOCALE_CODES, type Locale } from '../../i18n/config';
import ContactContent from '../../components/pages/ContactContent.astro';

export function getStaticPaths() {
	return LOCALE_CODES.filter((l) => l !== 'en').map((locale) => ({
		params: { locale },
	}));
}

const locale = Astro.params.locale as Locale;
const ui = await getStrings(locale);
---
<Layout title={`${ui.nav.contact} - ${ui.seo.siteTitle}`} locale={locale} ui={ui}>
  <ContactContent />
</Layout>
