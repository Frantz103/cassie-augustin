---
import Layout from '../components/Layout.astro';
import '../styles/lookbook.css';
import { getLocale } from '../i18n/utils';
import { getStrings } from '../i18n/getStrings';
import type { Locale } from '../i18n/config';
import LookbookContent from '../components/pages/LookbookContent.astro';

const locale = getLocale(Astro) as Locale;
const ui = await getStrings(locale);
---
<Layout title={`${ui.seo.siteTitle} - ${ui.nav.lookbook}`} locale={locale} ui={ui}>
  <LookbookContent />
</Layout>
