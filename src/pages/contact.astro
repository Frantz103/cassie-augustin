---
import Layout from '../components/Layout.astro';
import '../styles/contact.css';
import { getLocale } from '../i18n/utils';
import { getStrings } from '../i18n/getStrings';
import type { Locale } from '../i18n/config';
import ContactContent from '../components/pages/ContactContent.astro';

const locale = getLocale(Astro) as Locale;
const ui = await getStrings(locale);
---
<Layout title={`${ui.nav.contact} - ${ui.seo.siteTitle}`} locale={locale} ui={ui}>
  <ContactContent />
</Layout>
