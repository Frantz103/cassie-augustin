---
import Layout from '../components/Layout.astro';
import '../styles/contact.css';
import { useSanity } from '../lib/useSanity';
import { getSiteSettings } from '../lib/sanityQueries';
import { safeExternalUrl } from '../lib/contentSafety';

const useCms = useSanity();
const settingsData = useCms ? await getSiteSettings() : null;

const contactIntro = settingsData?.contactIntro || "I'd love to connect with you! Whether you're interested in nutrition guidance, modeling collaborations, or just want to say hello, I'm here for it.";
const contactOutro = settingsData?.contactOutro || "I share nutrition tips, wellness insights, behind-the-scenes from photoshoots, and everything in between. Let's start this journey together!";
const email = settingsData?.email || 'augustincassie@gmail.com';
const instagram = settingsData?.instagram || '@cassie.augustin';
const defaultInstagramUrl = 'https://www.instagram.com/cassie.augustin';
const instagramUrl = safeExternalUrl(settingsData?.instagramUrl, {
  fallback: defaultInstagramUrl,
  allowedHosts: ['instagram.com', 'www.instagram.com'],
  allowedProtocols: ['https:'],
});
---
<Layout title="Contact - Ludnie Cassie Augustin">
  <main>
    <div class="container">
      <article class="contact-content">
        <div class="breadcrumb pl-2">
          <a href="/">Home</a> / Contact
        </div>
        <h1 class="contact-title pl-2">Let's Connect</h1>

        <div class="contact-body pl-2 pr-mobile-2">
          <p>{contactIntro}</p>

          <div class="contact-links">
            <p><strong>Follow me on Instagram:</strong><br/>
            <a href={instagramUrl} target="_blank" rel="noopener noreferrer">{instagram}</a></p>

            <p><strong>Email me:</strong><br/>
            <a href={`mailto:${email}`}>{email}</a></p>
          </div>

          <p>{contactOutro}</p>

          <h2 class="form-heading">Send a Message</h2>
          <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="contact-form">
            <input type="hidden" name="form-name" value="contact" />
            <p class="hidden" aria-hidden="true">
              <label>Don't fill this out: <input name="bot-field" /></label>
            </p>
            <div class="form-group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" required />
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" required />
            </div>
            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="5" required></textarea>
            </div>
            <button type="submit" class="cta-button">Send</button>
          </form>
        </div>
      </article>
    </div>
  </main>
</Layout>
