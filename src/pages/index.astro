---
import Layout from '../components/Layout.astro';
import Modal from '../components/Modal.astro';
import { useSanity } from '../lib/useSanity';
import { getHomepage } from '../lib/sanityQueries';
import { urlFor } from '../lib/sanity';
import { sanitizeCmsText } from '../lib/contentSafety';

const useCms = useSanity();
const homeData = useCms ? await getHomepage() : null;

// Fallbacks
const heroTitle = homeData?.heroTitle || "Hi, I'm Cassie";
const heroSubtitle = homeData?.heroSubtitle || "I am a nutritionist passionate about women health, fashion, and modeling.";
const ctaText = homeData?.ctaText || "Let's Connect";
const ctaSubtextRaw =
	homeData?.ctaSubtext || 'Follow along for nutrition tips, modeling work,\n and wellness inspiration.';
const ctaSubtext = sanitizeCmsText(ctaSubtextRaw);
const heroImage = homeData?.heroImage ? urlFor(homeData.heroImage).url() : "/assets/img/Ludnie.jpg";
const heroImageAlt = homeData?.heroImageAlt || "A portrait of Ludnie Augustin showcasing her natural curly hair and bold makeup, with a focus on her expressive eyes and glossy lips, complemented by elegant earrings.";
---
<Layout title={`Ludnie Cassie Augustin - ${heroTitle}`}>
  <main>
  <div class="container">
  <div class="row">
    <div class="six columns">
      <div class="intro-container">
      <h1 class="pl-2">{heroTitle}</h1>
      <p class="intro pl-2 pr-mobile-2 ">{heroSubtitle}</p>
      
       <div class="cta-container ml-2">
          <a href="#" data-micromodal-trigger="modal-contact" class="cta-button">{ctaText}</a>
          <p class="preline-text">{ctaSubtext}</p>
        </div> 
      </div>
    </div>
    <div class="six columns image-container hide-on-mobile  ">
      <img class="u-max-full-width float-image " src={heroImage} alt={heroImageAlt} class="float-image">
      <div class="vertical-bar-container">
        <span class="bar-number">01</span>
        <!-- Your bar image goes here -->
        <img src="/assets/icons/bar.png" alt="Vertical bar" class="vertical-bar">
    </div>
    </div>
  </div>
  <Modal />
</div>
</Layout>
</main>
