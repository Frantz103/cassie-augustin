---
import Layout from '../components/Layout.astro';
import '../styles/homepage.css';
import { useSanity } from '../lib/useSanity';
import { getHomepage, getRecentBlogPosts, getTestimonials, getSiteSettings } from '../lib/sanityQueries';
import { getLookbookItems } from '../lib/lookbookQueries';
import { urlFor } from '../lib/sanity';
import { sanitizeCmsText } from '../lib/contentSafety';

const useCms = useSanity();
const [homeData, recentPosts, testimonials, lookbookItems, settings] = await Promise.all([
	useCms ? getHomepage() : null,
	useCms ? getRecentBlogPosts(3) : [],
	useCms ? getTestimonials() : [],
	useCms ? getLookbookItems() : [],
	useCms ? getSiteSettings() : null,
]);

// Hero fallbacks
const heroTitle = homeData?.heroTitle || "Hi, I'm Cassie";
const heroSubtitle = homeData?.heroSubtitle || "I am a nutritionist passionate about women health, fashion, and modeling.";
const credentials = homeData?.credentials || "Certified Nutritionist · Model · Wellness Advocate";
const ctaText = homeData?.ctaText || "Get in Touch";
const ctaSubtextRaw =
	homeData?.ctaSubtext || 'Follow along for nutrition tips, modeling work,\n and wellness inspiration.';
const ctaSubtext = sanitizeCmsText(ctaSubtextRaw);
const heroImage = homeData?.heroImage ? urlFor(homeData.heroImage).url() : "/assets/img/Ludnie.jpg";
const heroImageAlt = homeData?.heroImageAlt || "Portrait of Ludnie Cassie Augustin";

// Lookbook preview — pick up to 4 featured or first items
const featuredLookbook = lookbookItems
	.filter((item) => item.featured)
	.slice(0, 4);
const lookbookPreview = featuredLookbook.length > 0
	? featuredLookbook
	: lookbookItems.slice(0, 4);
---
<Layout title={`Ludnie Cassie Augustin - ${heroTitle}`}>
  <main>

  <!-- Hero Section -->
  <div class="container">
  <div class="row hero-row">
    <div class="six columns">
      <div class="intro-container">
      <h1 class="pl-2">{heroTitle}</h1>
      <p class="credentials pl-2">{credentials}</p>
      <p class="intro pl-2 pr-mobile-2">{heroSubtitle}</p>

       <div class="cta-container ml-2">
          <a href="/contact" class="cta-button">{ctaText}</a>
          <p class="preline-text">{ctaSubtext}</p>
        </div>
      </div>
    </div>
    <div class="six columns image-container hero-image-col">
      <img class="u-max-full-width float-image" src={heroImage} alt={heroImageAlt}>
      <div class="vertical-bar-container">
        <span class="bar-number">01</span>
        <img src="/assets/icons/bar.png" alt="" class="vertical-bar">
      </div>
    </div>
  </div>
  </div>

  <!-- Latest Blog Posts -->
  {recentPosts.length > 0 && (
  <section class="homepage-section">
    <div class="container">
      <h2 class="section-heading">Latest Articles</h2>
      <div class="post-grid">
        {recentPosts.map((post) => {
          const img = post.heroImage?.url
            ? urlFor(post.heroImage).width(600).auto('format').url()
            : null;
          return (
            <a href={`/blog/${post.slug}/`} class="post-card">
              {img && <img src={img} alt={post.heroImage?.alt || post.title} loading="lazy" width="600" height="400" />}
              <div class="post-card-body">
                {post.category && <span class="post-category">{post.category}</span>}
                <h3>{post.title}</h3>
                {post.description && <p>{post.description.slice(0, 120)}{post.description.length > 120 ? '…' : ''}</p>}
              </div>
            </a>
          );
        })}
      </div>
      <div class="section-cta">
        <a href="/blog" class="outline-link">View All Articles</a>
      </div>
    </div>
  </section>
  )}

  <!-- Featured Lookbook -->
  {lookbookPreview.length > 0 && (
  <section class="homepage-section lookbook-preview-section">
    <div class="container">
      <h2 class="section-heading">Lookbook</h2>
      <div class="lookbook-preview-grid">
        {lookbookPreview.map((item) => {
          const image = item.images?.[0];
          const imgUrl = image ? urlFor(image).width(800).auto('format').url() : '';
          return (
            <div class="lookbook-preview-item">
              {imgUrl && <img src={imgUrl} alt={image?.alt || item.title} loading="lazy" width="800" height="1000" />}
            </div>
          );
        })}
      </div>
      <div class="section-cta">
        <a href="/lookbook" class="outline-link">View Full Lookbook</a>
      </div>
    </div>
  </section>
  )}

  <!-- Testimonials -->
  {testimonials.length > 0 && (
  <section class="homepage-section testimonials-section">
    <div class="container">
      <h2 class="section-heading">Kind Words</h2>
      <div class="testimonials-grid">
        {testimonials.slice(0, 3).map((t) => (
          <blockquote class="testimonial-card">
            <p>"{t.content}"</p>
            <cite>— {t.name}</cite>
          </blockquote>
        ))}
      </div>
    </div>
  </section>
  )}

  </main>
</Layout>
