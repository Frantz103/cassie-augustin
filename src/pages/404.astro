---
import Layout from "../components/Layout.astro";
import { getLocale, localePath } from "../i18n/utils";
import { getStrings } from "../i18n/getStrings";
import type { Locale } from "../i18n/config";

const locale = getLocale(Astro) as Locale;
const ui = await getStrings(locale);
---

<Layout
  title={`${ui.notFound.title} — ${ui.seo.siteTitle}`}
  locale={locale}
  ui={ui}
>
  <main>
    <div class="container">
      <div class="not-found">
        <h1>{ui.notFound.title}</h1>
        <p>{ui.notFound.message}</p>
        <a href={localePath("/", locale)} class="cta-button"
          >{ui.notFound.backHome}</a
        >
      </div>
    </div>
  </main>
</Layout>

<style>
  .not-found {
    text-align: center;
    padding: 6rem 1.5rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .not-found h1 {
    font-family: var(--font-heading);
    font-size: var(--text-page-title);
    letter-spacing: 4px;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .not-found p {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--text-dark);
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .not-found .cta-button {
    margin-top: 0;
  }
</style>
