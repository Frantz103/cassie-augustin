---
import { useSanity } from '../lib/useSanity';
import { getSiteSettings } from '../lib/sanityQueries';

const useCms = useSanity();
const settings = useCms ? await getSiteSettings() : null;
const instagramUrl = settings?.instagramUrl || 'https://www.instagram.com/cassie.augustin';
const instagramHandle = settings?.instagram || '@cassie.augustin';
---
<footer class="footer">
    <nav class="footer-nav">
      <ul class="footer-links">
        <li><a href="/about">About</a></li>
        <li><a href="/lookbook">Lookbook</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/contact">Contact</a></li>
        <li class="footer-instagram"><a href={instagramUrl} target="_blank" rel="noopener noreferrer">{instagramHandle}</a></li>
      </ul>
    </nav>
</footer>
