---
import FormattedDate from '../FormattedDate.astro';
import { getCollection } from 'astro:content';
import { useSanity } from '../../lib/useSanity';
import { getBlogPosts, getWithFallback } from '../../lib/sanityQueries';
import { getLocale, localePath } from '../../i18n/utils';
import { getStrings } from '../../i18n/getStrings';
import type { Locale } from '../../i18n/config';
import { DEFAULT_LOCALE } from '../../i18n/config';

const locale = getLocale(Astro) as Locale;
const ui = await getStrings(locale);

const useCms = useSanity();

const markdownPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const cmsPosts = useCms ? (await getWithFallback(getBlogPosts, locale)) || [] : [];

const posts = cmsPosts.length
	? cmsPosts.map((post) => ({
			title: post.title,
			slug: post.slug,
			description: post.description,
			pubDate: post.publishedAt ? new Date(post.publishedAt) : new Date(),
			heroImage: post.heroImage?.url,
	  }))
	: markdownPosts.map((post) => ({
			title: post.data.title,
			slug: post.slug,
			description: post.data.description,
			pubDate: post.data.pubDate,
			heroImage: post.data.heroImage,
	  }));
---

<section class="blog">
    {posts.length > 0 ? (
    <ul>
        {
            posts.map((post) => (
                <li>
                    <a class="h-link" href={localePath(`/blog/${post.slug}/`, locale)}>
                        <h4 class="title">{post.title}</h4></a>
                        <p class="date">
                            <FormattedDate date={post.pubDate} locale={locale} />
                        </p>
                        <hr />
                        <p>{post.description}</p>
                        <p><a href={localePath(`/blog/${post.slug}/`, locale)}>{ui.blog.continueReading}</a></p>
                </li>
            ))
        }
    </ul>
    ) : (
        <p style="text-align:center; padding:4rem 1rem;">{ui.blog.noPosts}</p>
    )}
</section>
