---
const gaId = import.meta.env.PUBLIC_GA_ID || '';
const siteUrl = import.meta.env.SITE_URL || '';
const { title, description = "Ludnie Cassie Augustin - Nutritionist, Model, and Miss Choucoune International 2024 contestant. Empowering women through nutrition and wellness." } = Astro.props;
const canonicalUrl = siteUrl ? new URL(Astro.url.pathname, siteUrl).href : '';
const ogImageUrl = siteUrl ? `${siteUrl}/assets/img/Ludnie.jpg` : '/assets/img/Ludnie.jpg';

const personJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Ludnie Cassie Augustin",
  "url": siteUrl || undefined,
  "image": ogImageUrl,
  "jobTitle": "Nutritionist",
  "description": description,
  "sameAs": [
    "https://www.instagram.com/cassie.augustin"
  ]
});
---
<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content={description}>
    <meta name="author" content="Ludnie Cassie Augustin">

    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

    <!-- Open Graph / Social Media -->
    <meta property="og:type" content="website">
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:image" content={ogImageUrl}>
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta name="google-site-verification" content="aULVjtuSRDv7GETE3xCgYPGdyXaP6FNkono6cHGYpV8" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={personJsonLd} />

    <link rel="icon" type="image/x-icon" href="/assets/favicon.png"/>
    <!-- Ensure the paths here are correct -->
    <link rel="stylesheet" href="/normalize.css"/>
    <link rel="stylesheet" href="/skeleton.css"/>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,300;0,400;0,700;1,400&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet">
	<title>{title}</title>
  <script src="/assets/js/micromodal.min.js" defer></script>
  <script src="/assets/js/site-core.js" defer></script>

  <!-- Google tag (gtag.js) -->
  {gaId && <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>}
  {gaId && <script src="/assets/js/analytics-init.js" defer></script>}
</head>
